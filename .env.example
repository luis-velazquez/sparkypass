# SparkyPass Environment Variables
# Copy this file to .env.local and fill in your values

# NextAuth.js Configuration
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# Mobile auth (JWT signing for /api/auth/mobile/*)
# REQUIRED for the mobile app to sign in (email/Apple/Google). Distinct from
# NEXTAUTH_SECRET so mobile and web blast radii stay separate. Without it,
# /api/auth/mobile/* returns 500. Generate with: openssl rand -base64 64
MOBILE_JWT_SECRET=your-mobile-jwt-secret-here

# RevenueCat (in-app purchases)
# REVENUECAT_WEBHOOK_SECRET: shared secret for the inbound RC webhook
# (app/api/webhooks/revenuecat). Set the SAME value as the RC dashboard webhook
# "Authorization: Bearer <value>" header. Without it the webhook returns 500 and
# NO Apple purchase ever mirrors to the users table. Generate with: openssl rand -hex 32
REVENUECAT_WEBHOOK_SECRET=your-revenuecat-webhook-secret-here
# REVENUECAT_SECRET_API_KEY: RC REST v1 SECRET key (RC dashboard -> API keys).
# Needed only for the Stripe->RC mirror (lib/revenuecat.ts) + backfill script.
REVENUECAT_SECRET_API_KEY=your-revenuecat-secret-api-key-here

# Database (Turso/libSQL)
# For local development: file:./sparkypass.db (uses local SQLite file)
# For production: Get URL from Turso dashboard at https://turso.tech/
TURSO_DATABASE_URL=file:./sparkypass.db
# Auth token only needed for Turso cloud (not local development)
TURSO_AUTH_TOKEN=

# Google OAuth Provider
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth Provider
# Get credentials from: https://developers.facebook.com/apps/
FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret

# Apple OAuth Provider
# Get credentials from: https://developer.apple.com/account/resources/identifiers/list/serviceId
APPLE_CLIENT_ID=your-apple-client-id
APPLE_CLIENT_SECRET=your-apple-client-secret

# Email Service (Resend)
# Get your API key from https://resend.com
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=onboarding@resend.dev

# Contact Form Email
CONTACT_EMAIL=avgluis@gmail.com

# Sentry Error Tracking
# Create a project at https://sentry.io and get your DSN
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
